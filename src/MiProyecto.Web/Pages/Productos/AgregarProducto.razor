@page "/producto_agregar"
@inject HttpClient Http
@using MiProyecto.Application.Productos
@using MiProyecto.Domain
@inject ProductoOfflineService ProductoOfflineService
@inject NetworkService NetworkService
@using MiProyecto.Web.Models

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item"><a href="/productos">Productos</a></li>
        <li class="breadcrumb-item active" aria-current="page">Agregar Productos</li>
    </ol>
</nav>

<div class="d-flex align-items-center mb-4">
    <h3 class="m-0">Agregar Producto</h3>
</div>

@if (mensaje is not null)
{
    <div class="alert @(productoGuardado ? "alert-success" : "alert-danger")">
        @mensaje
    </div>
}

<EditForm Model="producto" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Nombre</label>
        <InputText class="form-control" @bind-Value="producto.Nombre" />
    </div>

    <div class="mb-3">
        <label>Precio</label>
        <InputNumber class="form-control" @bind-Value="producto.Precio" />
    </div>

    <button type="submit" class="btn btn-primary">
        Guardar
    </button>
</EditForm>

@code {
    Producto producto = new();
    bool productoGuardado = false;
    string? mensaje;

    private async Task Guardar()
    {
        bool online = await NetworkService.IsOnline();

        if (online)
        {
            var response = await Http.PostAsJsonAsync("api/producto", producto);

            if (response.IsSuccessStatusCode)
            {
                mensaje = "Producto guardado correctamente";
                productoGuardado = true;
                producto = new();
            }
            else
            {
                mensaje = "Error al guardar el producto";
                productoGuardado = false;
            }
        }
        else
        {
            var productoLocal = new ProductoLocal
            {
                Nombre = producto.Nombre,
                Precio = producto.Precio,
                IsSynced = false,
                LastModified = DateTime.UtcNow
            };

            await ProductoOfflineService.GuardarAsync(productoLocal);

            mensaje = "Producto guardado offline (se sincronizará después)";
            productoGuardado = true;
            producto = new();
        }

        await InvokeAsync(StateHasChanged);
        await Task.Delay(2000);
        mensaje = null;
        await InvokeAsync(StateHasChanged);
    }
}