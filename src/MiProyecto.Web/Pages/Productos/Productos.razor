@page "/productos"
@inject HttpClient Http
@inject IJSRuntime JS
@using MiProyecto.Domain
@using MiProyecto.Web.Services
@inject ProductoOfflineService ProductoOffline


<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item active" aria-current="page">Productos</li>
    </ol>
</nav>

<div class="d-flex align-items-center mb-4">
    <h3 class="m-0">Productos</h3>
    <a class="btn btn-primary ms-auto" href="/producto_agregar">Agregar</a>
</div>





@if (productos == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="w-100 table text-center">
    	<thead>
    		<tr>
    			<th>ID</th>
    			<th>Nombre</th>
    			<th>Precio</th>
                <th></th>
                <th></th>
                <th></th>
    		</tr>
    	</thead>
    	<tbody>    		
        @foreach (var p in productos)
        {
        	<tr>
            	<td>@p.Id_producto</td>
            	<td>@p.Nombre</td>
            	<td>@p.Precio</td>
                <td><a href="/producto/@p.Id_producto"><i class="bi bi-search text-success fs-4"></i></a></td>
                <td><a href="/producto/editar/@p.Id_producto"><i class="bi bi-pencil-square text-warning fs-4"></i></a></td>
                <td><i class="bi bi-trash3 text-danger fs-4" @onclick="() => Eliminar(p.Id_producto)"></i></td>
            </tr>
        }        	
        </tbody>
    </table>
}

@code {
    private List<Producto>? productos;

    protected override async Task OnInitializedAsync()
    {
        // 1️⃣ Cargar productos desde IndexedDB
        var offline = await ProductoOffline.ObtenerTodosAsync();

        if (offline != null && offline.Count > 0)
        {
            productos = offline.Select(p => new Producto
            {
                Id_producto = p.Id_producto,
                Nombre = p.Nombre,
                Precio = p.Precio
            }).ToList();
        }

        try
        {
            // 2️⃣ Intentar obtener datos desde la API
            var apiProductos = await Http.GetFromJsonAsync<List<Producto>>("api/producto");

            if (apiProductos != null)
            {
                productos = apiProductos;

                // 3️⃣ Guardar en IndexedDB
                await ProductoOffline.LimpiarAsync();

                foreach (var p in apiProductos)
                {
                    await ProductoOffline.GuardarAsync(new ProductoLocal
                    {
                        Id_producto = p.Id_producto,
                        Nombre = p.Nombre,
                        Precio = p.Precio
                    });
                }
            }
        }
        catch
        {
            // 4️⃣ Si falla la API (sin internet), usar los datos offline
        }
    }

    private async Task Eliminar(int id)
    {
        var confirmado = await JS.InvokeAsync<bool>(
            "confirm", "¿Seguro que deseas eliminar este producto?");

        if (!confirmado)
            return;

        var response = await Http.DeleteAsync($"api/producto/{id}");

        if (response.IsSuccessStatusCode)
        {
            // actualizar lista
            productos = await Http.GetFromJsonAsync<List<Producto>>("api/producto");

            // actualizar IndexedDB
            await ProductoOffline.LimpiarAsync();

            foreach (var p in productos)
            {
                await ProductoOffline.GuardarAsync(new ProductoLocal
                {
                    Id_producto = p.Id_producto,
                    Nombre = p.Nombre,
                    Precio = p.Precio
                });
            }
        }
    }
}