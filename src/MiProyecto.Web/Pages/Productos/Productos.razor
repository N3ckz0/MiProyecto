@page "/productos"
@inject HttpClient Http
@inject IJSRuntime JS
@using MiProyecto.Domain
@using MiProyecto.Web.Services
@inject ProductoOfflineService ProductoOffline
@inject NetworkService Network
@using System.Text.Json
@inject CambioProductoService CambioProductoService
@inject SincronizacionService Sync

//DEBUG
@inject IJSRuntime JS

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item active" aria-current="page">Productos</li>
    </ol>
</nav>

<div class="d-flex align-items-center mb-4">
    <h3 class="m-0">Productos</h3>
    <a class="btn btn-primary ms-auto" href="/producto_agregar">Agregar</a>
@if (tieneInternet)
{
    <button class="btn" @onclick="Sincronizar" disabled="@sincronizando">
        <i class="bi bi-arrow-repeat fs-4"></i>
    </button>
}
</div>

<button class="btn btn-secondary" @onclick="MostrarOfflineEnConsola">
    Mostrar offline en consola
</button>





@if (productos == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="w-100 table text-center">
    	<thead>
    		<tr>
    			<th>ID</th>
    			<th>Nombre</th>
    			<th>Precio</th>
                <th>Estado</th>
                <th></th>
                <th></th>
                <th></th>
    		</tr>
    	</thead>
    	<tbody>    		
        @foreach (var p in productos)
        {
        	<tr>
            	<td>@p.Id_producto</td>
            	<td>@p.Nombre</td>
            	<td>@p.Precio</td>
                <td>
                    <span class="badge @(p.IsOffline ? "bg-warning" : "bg-success")">
                        @(p.IsOffline ? "Offline" : "Online")
                    </span>
                </td>
                <td><a href="/producto/@p.Id_producto"><i class="bi bi-search text-dark fs-4"></i></a></td>
                <td><a href="/producto/editar/@p.Id_producto"><i class="bi bi-pencil-square text-dark fs-4"></i></a></td>
                <td><i class="bi bi-trash3 text-danger fs-4" @onclick="() => Eliminar(p.Id_producto)"></i></td>
            </tr>
        }        	
        </tbody>
    </table>
}

@code {
    private List<Producto> productos = new();
    private bool sincronizando = false;
    private bool tieneInternet = false;

    protected override async Task OnInitializedAsync()
    {
        // Actualizar el estado de la conexión
        Network.OnOnlineEvent -= Conectado;
        Network.OnOnlineEvent += Conectado;

        Network.OnOfflineEvent -= Desconectado;
        Network.OnOfflineEvent += Desconectado;

        await Network.RegisterConnectionEvents();

        tieneInternet = await Network.IsOnline();

        await CargarProductos();
    }

    private async Task Conectado()
    {
        tieneInternet = true;
        StateHasChanged();
    }

    private async Task Desconectado()
    {
        tieneInternet = false;
        StateHasChanged();
    }

    private async Task Sincronizar()
    {
        if (sincronizando)
            return;

        sincronizando = true;

        try
        {
            await Sync.SincronizarProductos();
            await CargarProductos();
        }
        finally
        {
            sincronizando = false;
            StateHasChanged();
        }
    }

    private void ReemplazarOffline(List<Producto> sincronizados)
    {
        foreach (var pOnline in sincronizados)
        {
            // Eliminar cualquier producto offline temporal con el mismo nombre
            productos.RemoveAll(p => p.IsOffline && p.Nombre == pOnline.Nombre);

            // Reemplazar si ya existe producto con Id real
            var index = productos.FindIndex(p => p.Id_producto == pOnline.Id_producto);
            if (index >= 0)
            {
                productos[index] = pOnline;
            }
            else
            {
                productos.Add(pOnline);
            }
        }
    }

    private async Task CargarProductos()
    {
        var productosTemp = new Dictionary<int, Producto>();
        var idsAgregados = new HashSet<int>();

        // 1️⃣ Agregar productos offline no sincronizados
        var offline = await ProductoOffline.ObtenerTodosAsync();
        if (offline != null)
        {
            foreach (var p in offline)
            {
                if (!p.IsSynced && !idsAgregados.Contains(p.Id_producto))
                {
                    productosTemp[p.Id_producto] = new Producto
                    {
                        Id_producto = p.Id_producto,
                        Nombre = p.Nombre,
                        Precio = p.Precio,
                        IsOffline = true
                    };
                    idsAgregados.Add(p.Id_producto);
                }
            }
        }

        // 2️⃣ Agregar productos del API
        try
        {
            var apiProductos = await Http.GetFromJsonAsync<List<Producto>>("api/producto");
            if (apiProductos != null)
            {
                foreach (var p in apiProductos)
                {
                    // Si ya existe producto temporal offline con el mismo Id temporal
                    var tempOffline = offline.FirstOrDefault(x => x.Id_producto == p.Id_producto || x.Nombre == p.Nombre);

                    if (tempOffline != null)
                    {
                        // reemplazar offline por online
                        productosTemp[p.Id_producto] = new Producto
                        {
                            Id_producto = p.Id_producto,
                            Nombre = p.Nombre,
                            Precio = p.Precio,
                            IsOffline = false
                        };
                    }
                    else if (!productosTemp.ContainsKey(p.Id_producto))
                    {
                        // agregar online normal
                        productosTemp[p.Id_producto] = new Producto
                        {
                            Id_producto = p.Id_producto,
                            Nombre = p.Nombre,
                            Precio = p.Precio,
                            IsOffline = false
                        };
                    }

                    // Guardar en IndexedDB solo si no existe
                    if (!offline.Any(x => x.Id_producto == p.Id_producto))
                    {
                        await ProductoOffline.GuardoDeApiAsync(new ProductoLocal
                        {
                            Id_producto = p.Id_producto,
                            Nombre = p.Nombre,
                            Precio = p.Precio,
                            IsSynced = true,
                            LastModified = DateTime.UtcNow
                        });
                    }
                }
            }
        }
        catch
        {
            // No hay internet → mostrar solo los productos offline
        }

        // 3️⃣ Reemplazar la lista en memoria
        productos = productosTemp.Values.ToList();
        StateHasChanged(); // actualizar UI
    }

    private async Task Eliminar(int? id)
    {
        if (!id.HasValue)
            return;

        var confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Seguro que deseas eliminar el producto {id.Value}");
        if (!confirmado)
            return;

        productos.RemoveAll(p => p.Id_producto == id);

        try
        {
            await Http.DeleteAsync($"api/producto/{id}");
        }
        catch
        {
            // ignoramos error si está offline
        }

        // SIEMPRE registrar cambio offline
        await ProductoOffline.EliminarAsync(id.Value);
    }

    //DEBUG
    private async Task MostrarOfflineEnConsola()
    {
        // Mostrar productos offline
        var offline = await ProductoOffline.ObtenerTodosAsync();
        var json = JsonSerializer.Serialize(offline, new JsonSerializerOptions { WriteIndented = true });
        await JS.InvokeVoidAsync("console.log", "Productos offline:", json);

        // Mostrar TODOS los cambios, sin filtrar por Sincronizado
        var cambios = await CambioProductoService.ObtenerTodos();
        var json_mod = JsonSerializer.Serialize(cambios, new JsonSerializerOptions
        {
            WriteIndented = true
        });
        await JS.InvokeVoidAsync("console.log", "Todos los cambios:", json_mod);
    }
    
}