@page "/"
@layout EmptyLayout
@using MiProyecto.Web.Services
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IAuthService AuthService

@if (isChecking)
{
    <p>Verificando sesión...</p>
}
else
{
    <div id="login_page" class="container-fluid vh-100">
        <div class="row h-100">

            <!-- Lado decorativo -->
            <div class="d-none d-lg-flex col-lg-6 login-side">
                <div class="login-side-content">
                    <h2>Bienvenido</h2>
                    <p>Accede a tu sistema</p>
                </div>
            </div>

            <!-- Formulario -->
            <div class="col-12 col-lg-6 d-flex justify-content-center align-items-center">
                <div class="login-card">

                    <h3 class="mb-4 text-center">Login</h3>

                    <input class="form-control mb-3" @bind="username" placeholder="Usuario" />
                    <input class="form-control mb-3" @bind="password" type="password" placeholder="Contraseña" />

                    <button class="btn btn-primary w-100" @onclick="HandleLogin">
                        Entrar
                    </button>

                </div>
            </div>

        </div>
    </div>   
}

@code {
    private string username = string.Empty;
    private string password = string.Empty;
    private bool isChecking = true;

    protected override async Task OnInitializedAsync()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

        if (!string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/home");
            return;
        }

        isChecking = false;
    }

    private async Task HandleLogin()
    {
        var token = await AuthService.LoginAsync(username, password);
        if (!string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/home");
        }
    }
}