@page "/producto_agregar"
@inject NavigationManager Navigation
@inject ProductoService ProductoService
@inject OfflineQueueService QueueService
@inject NetworkService NetworkService
@using MiProyecto.Domain.Entities
@using System.Text.Json

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item"><a href="/productos">Productos</a></li>
        <li class="breadcrumb-item active" aria-current="page">Agregar Productos</li>
    </ol>
</nav>	

<div class="d-flex align-items-center mb-4">
    <h3 class="m-0">Agregar Producto</h3>
</div>

@if (mensaje is not null)
{
    <div class="alert @(productoGuardado ? "alert-success" : "alert-danger")">
        @mensaje
    </div>
}

<EditForm Model="producto" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Nombre</label>
        <InputText class="form-control" @bind-Value="producto.Nombre" />
    </div>

    <div class="mb-3">
        <label>Precio</label>
        <InputNumber class="form-control" @bind-Value="producto.Precio" />
    </div>

    <button type="submit" class="btn btn-primary">
        Guardar
    </button>
</EditForm>


@code{
    Producto producto = new();
    bool productoGuardado = false;
    string? mensaje;

    // Estado de la red
    private bool isOnline;

    protected override async Task OnInitializedAsync()
    {
        // Verifica el estado de la red
        isOnline = await NetworkService.IsOnline();
    }

    private async Task Guardar()
    {
        try
        {
            if (isOnline)
            {
                // Si está online, guarda el producto en la API
                var ok = await ProductoService.CrearProductoAsync(producto);

                if (ok)
                {
                    mensaje = "Producto guardado correctamente.";
                    productoGuardado = true;
                    Navigation.NavigateTo("/productos");  // Redirige a la lista de productos
                }
                else
                {
                    mensaje = "Error al guardar el producto en línea.";
                    productoGuardado = false;
                }
            }
            else
            {
                // Si está offline, encola la operación para procesarla después
                var operation = new OfflineOperation
                {
                    OperationType = "Create",
                    EntityData = JsonSerializer.Serialize(producto)
                };

                await QueueService.EnqueueAsync(operation); // Encola la operación

                mensaje = "Producto agregado a la cola para guardar cuando vuelva a estar online.";
                productoGuardado = true;

                Navigation.NavigateTo("/productos");  // Redirige a la lista de productos
            }
        }
        catch (Exception ex)
        {
            mensaje = $"Error al intentar guardar el producto: {ex.Message}";
            productoGuardado = false;
        }
    }
}