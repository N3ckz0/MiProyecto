@page "/producto/editar/{Id:int}"
@inject NavigationManager Navigation
@inject ProductoService ProductoService
@inject OfflineQueueService QueueService
@inject NetworkService NetworkService
@using MiProyecto.Domain.Entities
@using System.Text.Json

<h3>Editar Producto</h3>

@if (producto == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="producto" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label>Nombre</label>
            <InputText class="form-control" @bind-Value="producto.Nombre" />
        </div>

        <div class="mb-3">
            <label>Precio</label>
            <InputNumber class="form-control" @bind-Value="producto.Precio" />
        </div>

        <button type="submit" class="btn btn-primary">Guardar</button>
        <button type="button" class="btn btn-secondary"
                @onclick="Volver">Cancelar</button>
    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private ProductoDto? producto;
    private bool isOnline;

    protected override async Task OnParametersSetAsync()
    {
        isOnline = await NetworkService.IsOnline();

        var entity = await ProductoService.GetProductoByIdAsync(Id);

        if (entity != null)
        {
            // Mapear Producto → ProductoDto
            producto = new ProductoDto
            {
                Id_producto = entity.Id_producto,
                Nombre = entity.Nombre,
                Precio = entity.Precio
            };
        }
        else
        {
            // Producto no encontrado → redirigir al listado
            Navigation.NavigateTo("/productos");
        }
    }

    private async Task Guardar()
    {
        if (producto == null) return;

        var entity = new Producto
        {
            Id_producto = producto.Id_producto,
            Nombre = producto.Nombre,
            Precio = producto.Precio
        };

        try
        {
            if (isOnline)
            {
                // Online → actualizar API directamente
                var ok = await ProductoService.EditarProductoAsync(entity);
                if (!ok)
                    Console.WriteLine("Error al actualizar producto en línea");
            }
            else
            {
                // Offline → encolar operación Update
                var operation = new OfflineOperation
                {
                    OperationType = "Update",
                    EntityData = JsonSerializer.Serialize(entity),
                    CreatedAt = DateTime.UtcNow
                };
                await QueueService.EnqueueAsync(operation);

                // Opcional: actualizar cache local inmediatamente
                var productosCache = await ProductoService.GetProductosAsync();
                var index = productosCache.FindIndex(p => p.Id_producto == entity.Id_producto);
                if (index >= 0)
                    productosCache[index] = new ProductoDto
                    {
                        Id_producto = entity.Id_producto,
                        Nombre = entity.Nombre,
                        Precio = entity.Precio ?? 0,
                        SyncStatus = SyncStatus.PendingUpdate
                    };
                else
                    productosCache.Add(new ProductoDto
                    {
                        Id_producto = entity.Id_producto,
                        Nombre = entity.Nombre,
                        Precio = entity.Precio ?? 0,
                        SyncStatus = SyncStatus.PendingUpdate
                    });

                await ProductoService.GuardarProductosDtoEnCacheAsync(productosCache);
            }

            Navigation.NavigateTo("/productos");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error guardando producto: {ex.Message}");
        }
    }

    private void Volver()
    {
        Navigation.NavigateTo("/productos");
    }
}