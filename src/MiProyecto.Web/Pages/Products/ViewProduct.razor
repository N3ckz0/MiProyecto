@page "/producto/{Id:int}"
@inject ProductoService ProductoService
@inject OfflineCacheService CacheService
@inject NetworkService NetworkService
@using MiProyecto.Domain.Entities
@using System.Text.Json

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item"><a href="/productos">Productos</a></li>
        <li class="breadcrumb-item active" aria-current="page">Ver Producto</li>
    </ol>
</nav>

<div class="d-flex align-items-center mb-4">
    <h3>Detalle del Producto</h3>
</div>

@if (producto == null)
{
    <p>Cargando...</p>
}
else
{
    <div>
        <p><strong>ID:</strong> @producto.Id_producto</p>
        <p><strong>Nombre:</strong> @producto.Nombre</p>
        <p><strong>Precio:</strong> @producto.Precio</p>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Producto? producto;
    private bool isOnline;

    protected override async Task OnParametersSetAsync()
    {
        isOnline = await NetworkService.IsOnline();

        try
        {
            if (isOnline)
            {
                // Si estamos online, obtener desde la API
                producto = await ProductoService.GetProductoByIdAsync(Id);
            }
            else
            {
                // Si estamos offline, intentar obtenerlo desde la cache
                producto = await CacheService.GetProductoByIdAsync(Id);
            }

            // Si el producto no existe offline, mostrar un mensaje de error
            if (producto == null && !isOnline)
            {
                Console.WriteLine("Producto no encontrado en cache mientras está offline.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error obteniendo producto: {ex.Message}");
            producto = null;
        }
    }
}