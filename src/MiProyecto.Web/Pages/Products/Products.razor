@page "/productos"
@inject NetworkService NetworkService
@inject ProductoService ProductoService

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item active">Productos</li>
    </ol>
</nav>

<div class="d-flex align-items-center mb-4">
    <h3 class="m-0">Productos</h3>
    <a class="btn btn-primary ms-auto" href="/producto_agregar">Agregar</a>
@if( isOnline ){
    <button class="btn" @onclick="Recargar">
        <i class="bi bi-arrow-repeat fs-4"></i>
    </button>
}
</div>


@if (productos == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="w-100 table text-center">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Estado</th>
                <th></th>
                <th></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in productos.Where(x => x.SyncStatus != SyncStatus.PendingDelete))
        {
            <tr class="@GetRowClass(p)">
                <td>@p.Id_producto</td>
                <td>@p.Nombre</td>
                <td>@p.Precio</td>
                <td>
                    @switch (p.SyncStatus)
                    {
                        case SyncStatus.PendingCreate:
                            <span class="badge bg-warning">Creado offline</span>
                            break;
                        case SyncStatus.PendingUpdate:
                            <span class="badge bg-info">Editado offline</span>
                            break;
                        case SyncStatus.PendingDelete:
                            <span class="badge bg-danger">Eliminación pendiente</span>
                            break;
                        default:
                            <span class="badge bg-success">Sincronizado</span>
                            break;
                    }
                </td>

                <td>
                    <a href="/producto/@p.Id_producto">
                        <i class="bi bi-search text-success fs-4"></i>
                    </a>
                </td>
                <td>
                    <a href="/producto/editar/@p.Id_producto">
                        <i class="bi bi-pencil-square text-warning fs-4"></i>
                    </a>
                </td>
                <td>
                    <i class="bi bi-trash3 text-danger fs-4"
                       @onclick="() => Eliminar(p.Id_producto)">
                    </i>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<ProductoDto>? productos;
    private bool isOnline;

    protected override async Task OnInitializedAsync()
    {
        NetworkService.OnStatusChanged += HandleStatusChange;
        await NetworkService.InitializeAsync();

        isOnline = await NetworkService.IsOnline();

        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        productos = await ProductoService.GetProductosAsync();
    }

    private async Task Recargar()
    {
        await CargarProductos();
    }

    private void HandleStatusChange(bool online)
    {
        isOnline = online;
        _ = CargarProductos(); // recarga automática
        StateHasChanged();
    }

    private async Task Eliminar(int id)
    {
        var ok = await ProductoService.EliminarProductoAsync(id);

        if (ok || !isOnline)
        {
            await CargarProductos();
        }
    }

    private string GetRowClass(ProductoDto p)
    {
        return p.SyncStatus switch
        {
            SyncStatus.PendingCreate => "table-warning",
            SyncStatus.PendingUpdate => "table-info",
            SyncStatus.PendingDelete => "table-danger",
            _ => ""
        };
    }

    public async ValueTask DisposeAsync()
    {
        NetworkService.OnStatusChanged -= HandleStatusChange;
        await NetworkService.DisposeAsync();
    }
}